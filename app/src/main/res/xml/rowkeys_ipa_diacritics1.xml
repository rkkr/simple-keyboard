<merge
    xmlns:latin="http://schemas.android.com/apk/res-auto"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Tilde -->
    <Key
        android:keyLabel="◌̃"
        latin:keySpec="̃" />
    <!-- Agudo -->
    <Key
        android:keyLabel="◌́"
        latin:keySpec="́" />
    <!-- Grave -->
    <Key
        android:keyLabel="◌̀"
        latin:keySpec="̀" />
    <!-- Circunflexo -->
    <Key
        android:keyLabel="◌̂"
        latin:keySpec="̂" />
    <!-- Trema -->
    <Key
        android:keyLabel="◌̈"
        latin:keySpec="̈" />
    <!-- Macron -->
    <Key
        android:keyLabel="◌̄"
        latin:keySpec="̄" />
    <!-- Breve -->
    <Key
        android:keyLabel="◌̆"
        latin:keySpec="̆" />
    <!-- Caron -->
    <Key
        android:keyLabel="◌̌"
        latin:keySpec="̌" />
    <!-- Anel -->
    <Key
        android:keyLabel="◌̊"
        latin:keySpec="̊" />
    <!-- Cedilha -->
    <Key
        android:keyLabel="◌̧"
        latin:keySpec="̧" />
</merge>